# Copy to .env and fill in. Used by send_email.py and gpu_idle_alert.sh.

# --- SMTP (idle/alert email) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASSWORD=your-app-password
SMTP_TO=you@example.com
# SMTP_FROM=you@example.com   # defaults to SMTP_USER

# --- GPU idle alert thresholds ---
GPU_IDLE_UTIL_THRESHOLD=5      # % at/below which a GPU counts as idle
GPU_IDLE_SAMPLES=60            # samples that must all be idle
GPU_IDLE_INTERVAL=10           # seconds between samples
GPU_IDLE_STATE_FILE=/tmp/gpu_idle_alert.state
GPU_IDLE_NOTIFY_BUSY=0         # 1 = also email when GPU returns to busy

# --- Power cap (reference; applied via gpu_power.py, not read automatically) ---
# GPU_POWER_CAP_W=300
